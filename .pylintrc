[MAIN]
# Make the collection importable as ansible_collections.starnix.unifi.* so
# pylint resolves intra-collection imports. Run pylint from the collection root.
init-hook='import os, sys; sys.path.insert(0, os.path.abspath("../../.."))'

[MESSAGES CONTROL]
# R0801 (duplicate-code) fires on the small, repeated test-double boilerplate
# across unit tests; it is noisy by design there and not actionable.
disable=duplicate-code

[FORMAT]
max-line-length=79

[DESIGN]
# An HTTP client constructor legitimately takes the full connection tuple.
max-args=10
max-positional-arguments=10
max-attributes=10

[BASIC]
good-names=i,j,k,ex,_,e,um
